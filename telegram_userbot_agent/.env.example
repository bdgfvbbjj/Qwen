# Telegram Userbot Agent - .env example
# Скопируйте этот файл в .env и заполните своими данными

# Telegram API credentials (получить на my.telegram.org)
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_PHONE=+79991234567

# Gemini API key (получить на aistudio.google.com)
GEMINI_API_KEY=your_api_key_here

# Модели Gemini для переключения при лимитах (порядок важен: от лучших к худшим!)
# По умолчанию: gemini-1.5-pro → gemini-2.0-flash-exp → gemini-1.5-flash
GEMINI_MODELS=gemini-1.5-pro,gemini-2.0-flash-exp,gemini-1.5-flash

# Разрешенные пользователи (Telegram username через запятую, опционально)
# Если не указано, разрешен только владелец аккаунта
ALLOWED_USERS=your_username
